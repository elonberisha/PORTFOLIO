NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Protects /studio in production. Set these in Vercel.
STUDIO_HOST=studio.elonberisha.com
STUDIO_BASIC_USER=your_studio_user
STUDIO_BASIC_PASSWORD=your_long_random_password

# Local scripts only. Never expose write tokens to the browser/runtime.
SANITY_API_WRITE_TOKEN=your_write_token_here
